<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>
<html b:css='false' b:defaultwidgetversion='2' b:layoutsVersion='3' b:responsive='true' b:templateVersion='1.0.0' expr:class='data:blog.languageDirection' expr:dir='data:blog.languageDirection' xmlns='http://www.w3.org/1999/xhtml' xmlns:b='http://www.google.com/2005/gml/b' xmlns:data='http://www.google.com/2005/gml/data' xmlns:expr='http://www.google.com/2005/gml/expr'>
<head>
    <b:include data='blog' name='all-head-content'/>
    <meta content='width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1' name='viewport'/>
    <title><data:blog.pageTitle/></title>
    
    <!-- Pinterest Verification -->
    <meta content='cc0a20c5fcb5f61af407cc22e08b9b74' name='p:domain_verify'/>
    
    <!-- SEO Meta Tags -->
    <meta content='Discover easy, delicious, and trending recipes. Your daily guide to cooking, baking, and meal planning!' name='description'/>
    
    <!-- Adsterra Pop Under -->
    <script src='https://pl29720489.effectivecpmnetwork.com/5a/f3/46/5af3461dd9388980b20ecef9e4d0c7fc.js' type='text/javascript'></script>
    
    <!-- Adsterra Social Bar -->
    <script src='https://pl29720492.effectivecpmnetwork.com/ca/01/05/ca0105967e5dd4d3ffac274deb62d9c9.js' type='text/javascript'></script>
    
    <b:skin version='1.0.0'><![CDATA[
    /* Minimal Fast CSS For Recipe Blog */
    body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; margin: 0; padding: 0; background-color: #fdfbf7; color: #333; line-height: 1.6; }
    header { background-color: #fff3e0; padding: 30px; text-align: center; border-bottom: 3px solid #ff5722; }
    header h1 { margin: 0; color: #e65100; font-size: 2.5em; text-transform: uppercase; letter-spacing: 2px; font-weight: bold; }
    header p { color: #555; font-style: italic; font-size: 1.1em; }
    .container { max-width: 800px; margin: 20px auto; padding: 0 15px; }
    .post { background: #fff; padding: 25px; margin-bottom: 30px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
    .post-title { font-size: 1.9em; margin-top: 0; color: #111; font-weight: bold; }
    .post-title a { color: #111; text-decoration: none; }
    .post-title a:hover { color: #ff5722; }
    .ad-slot { margin: 25px 0; text-align: center; overflow: hidden; }
    img { max-width: 100%; height: auto; border-radius: 6px; }
    a { color: #ff5722; text-decoration: none; font-weight: bold; }
    a:hover { text-decoration: underline; color: #e65100; }
    .post-body { font-size: 1.05em; color: #444; }
    ]]></b:skin>
</head>
<body>
    <header>
        <h1><data:blog.title/></h1>
        <p>Your Ultimate Guide to Delicious Recipes &amp; Meal Planning</p>
    </header>

    <!-- Top Banner 728x90 -->
    <div class='ad-slot'>
        <script type='text/javascript'>
//<![CDATA[
          atOptions = {
            'key' : '9e9591ee5caaf3856a6c97e122c187fc',
            'format' : 'iframe',
            'height' : 90,
            'width' : 728,
            'params' : {}
          };
//]]>
        </script>
        <script src='https://www.highperformanceformat.com/9e9591ee5caaf3856a6c97e122c187fc/invoke.js' type='text/javascript'></script>
    </div>

    <div class='container'>
        <b:section class='main' id='main' showaddelement='yes'>
            <b:widget id='Blog1' locked='true' title='Blog Posts' type='Blog' version='2'>
                <b:widget-settings>
                    <b:widget-setting name='showDateHeader'>true</b:widget-setting>
                </b:widget-settings>
                <b:includable id='main' var='top'>
                    <b:loop values='data:posts' var='post'>
                        <div class='post'>
                            <h2 class='post-title'>
                                <a expr:href='data:post.url'><data:post.title/></a>
                            </h2>
                            <div class='post-body'>
                                <data:post.body/>
                            </div>
                            
                            <!-- Ads Only show inside the post page (not on homepage) to avoid clutter -->
                            <b:if cond='data:blog.pageType == &quot;item&quot;'>
                                <!-- Middle Ad Native Banner -->
                                <div class='ad-slot'>
                                    <script async='async' data-cfasync='false' src='https://pl29720490.effectivecpmnetwork.com/6e77deaac5476599e55a66d0cf1aeef1/invoke.js' type='text/javascript'></script>
                                    <div id='container-6e77deaac5476599e55a66d0cf1aeef1'></div>
                                </div>
                                
                                <!-- Bottom Ad 300x250 (Optional fallback if needed, omitted for now since none provided) -->
                            </b:if>
                        </div>
                    </b:loop>
                </b:includable>
            </b:widget>
        </b:section>
    </div>
</body>
</html>
